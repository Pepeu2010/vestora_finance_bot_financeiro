{
  "name": "vestora",
  "version": "1.0.0",
  "description": "Vestora, plataforma web/PWA de educacao financeira e inteligencia financeira pessoal com Node.js e Groq.",
  "main": "server.js",
  "scripts": {
    "build": "vite build",
    "vercel-build": "vite build",
    "prestart": "npm run build",

    "dev:react": "vite --host 0.0.0.0 --port 3005",
    "test:web-search": "node --test tests/internet-search.test.js"
  },
  "keywords": [
    "vestora",
    "fintech",
    "educacao-financeira",
    "inteligencia-financeira",
    "groq",
    "pwa"
  ],
  "author": "",
